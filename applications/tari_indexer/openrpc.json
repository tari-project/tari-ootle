    "components": {
        "schemas": {
            "GetConnectionsResponse": {
                "type": "object",
                "properties": {
                    "connections": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Connection"
                        }
                    }
                },
                "required": [
                    "connections"
                ]
            },
            "Connection": {
                "type": "object",
                "properties": {
                    "address": {
                        "type": "string",
                        "description": "Multiaddress (onion3/TCP)"
                    },
                    "age": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Connection age in seconds"
                    },
                    "direction": {
                        "type": "boolean",
                        "description": "true=inbound, false=outbound"
                    },
                    "node_id": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]+$",
                        "description": "Hex-encoded peer NodeId"
                    },
                    "public_key": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]+$",
                        "description": "Hex-encoded public key"
                    }
                },
                "required": [
                    "address",
                    "age",
                    "direction",
                    "node_id",
                    "public_key"
                ]
            },
            "GetIdentityResponse": {
                "type": "object",
                "properties": {
                    "node_id": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]+$",
                        "description": "Hex-encoded NodeId"
                    },
                    "public_address": {
                        "type": "string"
                    },
                    "public_key": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]+$"
                    }
                },
                "required": [
                    "node_id",
                    "public_address",
                    "public_key"
                ]
            },
            "GetAddressesResponse": {
                "type": "array",
                "items": {
                    "type": "array",
                    "items": [
                        {
                            "type": "string",
                            "description": "Prefixed address string (e.g., \"component_<hex>\")"
                        },
                        {
                            "type": "integer",
                            "description": "Latest version number"
                        }
                    ],
                    "minItems": 2,
                    "maxItems": 2,
                    "additionalItems": false
                }
            },
            "GetSubstateRequest": {
                "type": "object",
                "properties": {
                    "address": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]+$",
                        "description": "Hex-encoded SubstateId as expected by the JSON API"
                    },
                    "version": {
                        "type": "integer",
                        "description": "Optional version number for the substate request"
                    },
                    "local_search_only": {
                        "type": "boolean",
                        "description": "Optional flag to restrict the search to local storage only"
                    }
                },
                "required": [
                    "address"
                ]
            },
            "GetSubstateResponse": {
                "type": "object",
                "properties": {
                    "address": {
                        "type": "string",
                        "pattern": "^[0-9a-fA-F]+$",
                        "description": "Hex-encoded SubstateId as returned by the JSON API"
                    },
                    "substate": {
                        "type": "object"
                    },
                    "version": {
                        "type": "integer"
                    }
                },
                "required": [
                    "address",
                    "substate",
                    "version"
                ]
            },
            "GetSubstatesRequest": {
                "type": "object",
                "properties": {
                    "requests": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/GetSubstateRequest"
                        }
                    }
                },
                "required": [
                    "requests"
                ]
            },
            "GetSubstatesResponse": {
                "type": "object",
                "properties": {
                    "responses": {
                        "type": "array",
                        "items": {
                            "anyOf": [
                                {
                                    "$ref": "#/components/schemas/GetSubstateResponse"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        }
                    }
                },
                "required": [
                    "responses"
                ]
            }
        }
    }
